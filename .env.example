# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nakliye_pazar
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=30d

# File uploads (local for now, swap for S3 later)
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# Cloudinary image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase Admin / push and phone verification
FIREBASE_SERVICE_ACCOUNT=

# Mail reports
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REPORT_TO_EMAIL=

# Optional CORS override
CORS_ORIGINS=
